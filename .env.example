# .env.example — copy to .env and fill in values before deploying.
#
# Local dev: the defaults in docker-compose.yml work fine — no .env needed.
# Production: create a .env file in the same directory as docker-compose.yml.

# ── Backend ──────────────────────────────────────────────────────────────

# SQLAlchemy database URL.
# SQLite (default): file is mounted at ./data/tallymancer.db
# Postgres example: postgresql://user:password@db:5432/tallymancer
DATABASE_URL=sqlite:////app/data/tallymancer.db

# Base URL used when generating share links.
# Must include the protocol and domain, no trailing slash.
# Production: https://tallymancer.com
PUBLIC_BASE_URL=https://tallymancer.com

# Sessions with no activity older than this many hours will be archived.
SESSION_EXPIRY_HOURS=48

# ── Traefik / networking (production only) ───────────────────────────────

# Domain for Traefik router rule and Let's Encrypt cert.
DOMAIN=tallymancer.com
