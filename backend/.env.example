# Copy this file to .env and fill in values for local development.
# Never commit a real .env file.

# SQLAlchemy database URL.
# For SQLite (local dev):  sqlite:///./tallymancer.db
# For Postgres (prod):     postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite:///./tallymancer.db

# Base URL used when generating shareable session links.
# In production this becomes https://tallymancer.com
PUBLIC_BASE_URL=http://localhost:8000

# Sessions inactive for longer than this many hours are archived (soft-expired).
SESSION_EXPIRY_HOURS=48
